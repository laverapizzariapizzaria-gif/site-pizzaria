<!doctype html>
<html lang="pt-br">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Cardápio</title>
  <style>
    :root{ --bg:#0b0b0b; --card:#121212; --muted:#bdbdbd; --line:#262626; --btn:#1f1f1f; --btn2:#2a2a2a; }
    *{ box-sizing:border-box; }
    body{ margin:0; font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial; background:var(--bg); color:#fff; }
    .topbar{ position:sticky; top:0; z-index:5; background:rgba(11,11,11,.92); backdrop-filter: blur(8px); border-bottom:1px solid var(--line); }
    .topbar-inner{ max-width:1100px; margin:0 auto; padding:14px 16px; display:flex; align-items:center; justify-content:space-between; gap:12px; }
    .brand{ display:flex; align-items:center; gap:10px; font-weight:800; letter-spacing:.2px; }
    .brand span{ opacity:.9; }
    .nav{ display:flex; gap:14px; align-items:center; }
    .nav a{ color:#fff; text-decoration:none; opacity:.9; }
    .nav a:hover{ opacity:1; text-decoration:underline; }
    .wrap{ max-width:1100px; margin:0 auto; padding:18px 16px 40px; }

    .cat{ margin:18px 0 26px; }
    .cat-title{ font-size:18px; font-weight:900; letter-spacing:.3px; padding:10px 12px; border:1px solid var(--line); border-radius:14px; background:linear-gradient(180deg,#151515,#0f0f0f); display:flex; align-items:center; justify-content:space-between; }
    .cat-title small{ color:var(--muted); font-weight:600; }

    .grid{ display:grid; grid-template-columns: repeat(auto-fill,minmax(320px,1fr)); gap:14px; margin-top:12px; }
    .card{ border:1px solid var(--line); background:var(--card); border-radius:18px; padding:12px; }
    .img{ width:100%; height:170px; border-radius:14px; object-fit:cover; border:1px solid var(--line); background:#0f0f0f; }
    .row{ display:flex; align-items:flex-start; justify-content:space-between; gap:10px; margin-top:10px; }
    .name{ font-weight:800; font-size:16px; }
    .desc{ margin-top:4px; color:var(--muted); font-size:13px; line-height:1.35; }
    .price{ font-weight:900; }

    .sizes{ margin-top:10px; display:flex; flex-direction:column; gap:8px; }
    .size{ display:flex; align-items:center; justify-content:space-between; gap:10px; padding:10px; border:1px solid var(--line); border-radius:14px; background:#0e0e0e; }
    .size-left{ min-width:0; }
    .size-left b{ display:block; }
    .size-left span{ color:var(--muted); font-size:12px; }

    .actions{ display:flex; align-items:center; gap:8px; }
    .qty{ width:74px; padding:10px 10px; border-radius:12px; border:1px solid #333; background:#0b0b0b; color:#fff; }
    .btn{ padding:10px 14px; border-radius:999px; border:1px solid #3a3a3a; background:var(--btn); color:#fff; cursor:pointer; font-weight:800; }
    .btn:hover{ background:var(--btn2); }
    .btn[disabled]{ opacity:.55; cursor:not-allowed; }
    .chip{ display:inline-flex; align-items:center; gap:6px; padding:6px 10px; border:1px solid var(--line); border-radius:999px; background:#0f0f0f; color:var(--muted); font-weight:700; font-size:12px; }

    .closed{ margin:14px 0; padding:12px; border:1px dashed #3b3b3b; border-radius:16px; background:#0f0f0f; color:var(--muted); }
  </style>
</head>
<body>
  <div class="topbar">
    <div class="topbar-inner">
      <div class="brand"><span>🍕</span><span>Cardápio</span></div>
      <div class="nav">
        <a href="{% url 'menu' %}">Cardápio</a>
        <a href="{% url 'cart' %}">Ver carrinho</a>
        {% if request.user.is_authenticated %}
          <a href="{% url 'my_orders' %}">Meus pedidos</a>
          <a href="{% url 'logout' %}">Sair</a>
        {% else %}
          <a href="{% url 'login' %}">Entrar</a>
        {% endif %}
      </div>
    </div>
  </div>

  <div class="wrap">
    {% if not store_open %}
      <div class="closed">⚠️ No momento estamos <b>fechados</b>. Você pode navegar no cardápio, mas não é possível adicionar itens.</div>
    {% endif %}

    {% for category in categories %}
      <section class="cat" id="cat-{{ category.id }}">
        <div class="cat-title">
          <span>{{ category.name }}</span>
          <small>{{ category.products.count }} item(ns)</small>
        </div>

        <div class="grid">
          {% for product in category.products.all %}
            <div class="card">
              {% if product.image %}
                <img class="img" src="{{ product.image.url }}" alt="{{ product.name }}" />
              {% else %}
                <div class="img"></div>
              {% endif %}

              <div class="row">
                <div style="min-width:0">
                  <div class="name">{{ product.name }}</div>
                  {% if product.description %}<div class="desc">{{ product.description }}</div>{% endif %}
                </div>
                <div class="price">R$ {{ product.price }}</div>
              </div>

              
              {% if product.sizes.exists %}
                <div class="sizes">
                  {% for size in product.sizes.all %}
                    <div class="size">
                      <div class="size-left">
                        <b>{{ size.name }}</b>
                        {% if size.description %}<span>{{ size.description }}</span>{% endif %}
                      </div>
                      <div class="price">R$ {{ size.price }}</div>
                    </div>
                  {% endfor %}
                </div>
                <div style="margin-top:10px; display:flex; justify-content:flex-end;">
                  <a class="btn" href="{% url 'addons_select' product.id %}" {% if not store_open %}style="pointer-events:none; opacity:.55"{% endif %}>Adicionar</a>
                </div>
              {% elif product.addons.exists %}
                <div style="margin-top:10px; display:flex; justify-content:flex-end;">
                  <a class="btn" href="{% url 'addons_select' product.id %}" {% if not store_open %}style="pointer-events:none; opacity:.55"{% endif %}>Adicionar</a>
                </div>
              {% else %}
                <form method="post" action="{% url 'cart_add' product.id %}" style="margin-top:10px; display:flex; justify-content:flex-end;">
                  {% csrf_token %}
                  <input type="hidden" name="qty" value="1" />
                  <button class="btn" type="submit" {% if not store_open %}disabled{% endif %}>Adicionar</button>
                </form>
              {% endif %}

                  <a class="btn" href="{% url 'addons_select' product.id %}" {% if not store_open %}style="pointer-events:none; opacity:.55"{% endif %}>Adicionar</a>
                </div>
              {% else %}
                <form method="post" action="{% url 'cart_add' product.id %}" style="margin-top:10px; display:flex; justify-content:flex-end;">
                  {% csrf_token %}
                  <input type="hidden" name="qty" value="1" />
                  <button class="btn" type="submit" {% if not store_open %}disabled{% endif %}>Adicionar</button>
                </form>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </section>
    {% endfor %}
  </div>
</body>
</html>
